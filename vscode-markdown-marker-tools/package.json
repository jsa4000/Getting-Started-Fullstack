{
  "name": "vscode-markdown-marker-tools",
  "displayName": "Markdown Marker Tools",
  "description": "Detects various makers in code and shows a CodeLens to create/update that file",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown Marker Tools",
      "properties": {
        "markdownMarkerTools.openFileAfterCreate": {
          "type": "boolean",
          "default": false,
          "description": "Open the file in the editor after creating or updating it via a COPY marker."
        }
      }
    },
    "commands": [
      {
        "command": "copyMarkerToFile.create",
        "title": "Copy Marker: Create / Update File"
      },
      {
        "command": "copyMarkerToFile.runInTerminal",
        "title": "Copy Marker: Run in Terminal"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
