{
  "name": "copy-marker-to-file",
  "displayName": "Copy Marker to File",
  "description": "Detects // COPY: path comments in code and shows a CodeLens to create/update that file",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyMarkerToFile.create",
        "title": "Copy Marker: Create / Update File"
      },
      {
        "command": "copyMarkerToFile.runInTerminal",
        "title": "Copy Marker: Run in Terminal"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
